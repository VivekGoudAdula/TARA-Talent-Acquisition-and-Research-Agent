# MongoDB / Azure Cosmos DB (MongoDB API)
MONGODB_URI=
MONGODB_DB_NAME=Tara

# Excel data sources (IDBI Innovate architecture)
EXTERNAL_LEADS_EXCEL_PATH=external_leads_1000.xlsx
CUSTOMER_MASTER_EXCEL_PATH=customer_master_1000.xlsx
TRANSACTION_HISTORY_EXCEL_PATH=transaction_history_15000.xlsx
LOAN_HISTORY_EXCEL_PATH=loan_history_1000.xlsx
DIGITAL_ACTIVITY_EXCEL_PATH=digital_activity_1000.xlsx

# OpenAI (Explainable AI layer — preferred when set)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Azure OpenAI (fallback if OPENAI_API_KEY is not set)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_API_VERSION=2024-12-01-preview
AZURE_GPT_DEPLOYMENT=gpt-4o
EXPLAINABILITY_USE_LLM=true

# Vanguard Voice platform (bank/bank) — Twilio Voice + Media Streams
VOICE_AGENT_BASE_URL=http://localhost:9000
VOICE_AGENT_DEFAULT_AGENT_ID=lending_offer_agent

# Twilio — SMS + WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_CONTENT_SID=
TWILIO_WHATSAPP_USE_TEMPLATE=false

# Email — smtp or sendgrid
EMAIL_PROVIDER=smtp
EMAIL_FROM_ADDRESS=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SENDGRID_API_KEY=

ENGAGEMENT_BANK_NAME=IDBI Bank
