# MongoDB / Azure Cosmos DB (MongoDB API)
MONGODB_URI=
MONGODB_DB_NAME=Tara

# Excel data sources (paths relative to backend/ or absolute)
EXTERNAL_LEADS_EXCEL_PATH=external_leads_1000.xlsx
CUSTOMER_MASTER_EXCEL_PATH=customer_master_1000.xlsx
TRANSACTION_HISTORY_EXCEL_PATH=transaction_history_15000.xlsx
LOAN_HISTORY_EXCEL_PATH=loan_history_1000.xlsx
DIGITAL_ACTIVITY_EXCEL_PATH=digital_activity_1000.xlsx
EXPECTED_CUSTOMER_COUNT=1000
EXPECTED_LEAD_COUNT=1000

# OpenAI (Explainable AI layer — preferred when set)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Azure OpenAI (fallback if OPENAI_API_KEY is not set)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_API_VERSION=2024-12-01-preview
AZURE_GPT_DEPLOYMENT=gpt-4o
EXPLAINABILITY_USE_LLM=true

# Vanguard Voice platform (bank/bank) — Twilio Voice + Media Streams
VOICE_AGENT_BASE_URL=http://localhost:9000
VOICE_AGENT_DEFAULT_AGENT_ID=lending_offer_agent

# Twilio — SMS + WhatsApp (+ voice via bank/bank)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_CONTENT_SID=
TWILIO_WHATSAPP_USE_TEMPLATE=false

# Rich WhatsApp — Content Template SIDs (create in Twilio Content Editor)
WHATSAPP_WELCOME_MEDIA_URL=
WHATSAPP_CONTENT_MAIN_MENU=
WHATSAPP_CONTENT_LOAN_MEDIA=
WHATSAPP_CONTENT_PREAPPROVED_BUTTONS=
WHATSAPP_CONTENT_CREDIT_CARD_OFFER=

# Email — smtp or sendgrid
EMAIL_PROVIDER=smtp
EMAIL_FROM_ADDRESS=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SENDGRID_API_KEY=

ENGAGEMENT_BANK_NAME=IDBI Bank
ENGAGEMENT_EMAIL_CTA_URL=https://www.idbibank.in/
ENGAGEMENT_CALLBACK_PHONE=+911800209435
ENGAGEMENT_DEFAULT_ELIGIBLE_AMOUNT=1500000
ENGAGEMENT_DEFAULT_INTEREST_RATE=8.25
ENGAGEMENT_OFFER_VALID_UNTIL=31 Jul 2026

# Public Tara API base URL for email/WhatsApp callback CTAs (use ngrok URL, not localhost)
ENGAGEMENT_API_BASE_URL=http://localhost:8000
ENGAGEMENT_USE_LAN_IP=true

# Engagement test routing (optional — routes outreach to test recipients)
ENGAGEMENT_TEST_MODE=false
ENGAGEMENT_WHATSAPP_OVERRIDE_PHONE=
ENGAGEMENT_SMS_TEST_PHONES=
ENGAGEMENT_EMAIL_TEST_ADDRESSES=
ENGAGEMENT_TEST_OFFSET=0

# Pipeline / scheduler (optional)
PIPELINE_AUTO_RUN_ON_IMPORT=false
LEARNING_SCHEDULER_ENABLED=false
LEARNING_SCHEDULER_INTERVAL_HOURS=24
